{
  "agentType": "expert-profile",
  "version": "1.0.0",
  "displayName": "Expert Profile Extractor",
  "description": "Extracts structured expert profiles from faculty/researcher homepages using a rule-layer + LLM pipeline. Output uses the new compact schema: integer enum IDs for sex/country/domain/professional/title, comma-separated tag IDs, and direct field names matching the business API.",
  "skillRefs": [
    "/Users/jiahao/Desktop/PythonProject/pi/packages/agent-specs/skills/expert-profile-extractor/SKILL.md"
  ],
  "extensionRefs": [],
  "promptTemplates": [],
  "defaultModelPolicy": {
    "preferredRole": "default",
    "providerAllowlist": ["aliyun-bailian"],
    "modelAllowlist": ["glm-5.1"],
    "failoverOrder": [
      { "provider": "aliyun-bailian", "model": "glm-5.1" }
    ],
    "maxAttemptsPerProvider": 1,
    "thinkingLevel": "off",
    "maxTokens": 8000
  },
  "defaultToolPolicy": {
    "mode": "allowlist",
    "tools": ["read", "bash", "ls"]
  },
  "defaultWorkspacePolicy": {
    "mode": "ephemeral",
    "retainOnFailure": true,
    "network": "enabled",
    "maxDiskMb": 512,
    "ttlMinutes": 15
  },
  "defaultCompactionPolicy": {
    "mode": "default",
    "preserveToolOutputs": true,
    "preserveRecentTurns": 4,
    "summarizeOlderThanTurns": 10,
    "emitCompactionDiagnostics": false
  },
  "outputContract": {
    "mode": "tool-submission",
    "requireSubmitResultTool": true,
    "textFallbackAllowed": false,
    "schema": {
      "type": "object",
      "required": [
        "avatar", "surname", "sex", "birthday", "country", "province", "city",
        "organization", "department", "domain", "direction", "professional",
        "position", "phone", "email", "contact", "content", "academic", "journal",
        "title", "tags"
      ],
      "properties": {
        "avatar":        { "type": ["string", "null"] },
        "surname":       { "type": ["string", "null"] },
        "sex":           { "type": "integer", "enum": [0, 1, 2] },
        "birthday":      { "type": ["string", "null"] },
        "country":       { "type": "integer" },
        "province":      { "type": "integer" },
        "city":          { "type": "integer" },
        "organization":  { "type": ["string", "null"] },
        "department":    { "type": ["string", "null"] },
        "domain":        { "type": "integer" },
        "direction":     { "type": ["string", "null"] },
        "professional":  { "type": "integer" },
        "position":      { "type": ["string", "null"] },
        "phone":         { "type": ["string", "null"] },
        "email":         { "type": ["string", "null"] },
        "contact":       { "type": ["string", "null"] },
        "content":       { "type": ["string", "null"] },
        "academic":      { "type": ["string", "null"] },
        "journal":       { "type": ["string", "null"] },
        "title":         { "type": "integer" },
        "tags":          { "type": ["string", "null"] }
      }
    }
  },
  "sessionReusePolicy": {
    "mode": "none",
    "persistent": false
  },
  "subagentPolicy": {
    "enabled": false,
    "maxDepth": 1,
    "maxBreadth": 1,
    "maxParallel": 1,
    "inheritWorkspace": true,
    "inheritToolPolicy": true,
    "inheritModelPolicy": true
  },
  "completionPolicy": {
    "requirePromptResolved": true,
    "requireTerminalEvent": true,
    "requireNoPendingWork": true,
    "requireSubmitResult": true,
    "settledTimeoutMs": 3000
  },
  "extensionGovernance": {
    "allowedExtensionRefs": [],
    "allowRuntimeInstall": false,
    "allowWorkspaceDiscovery": false,
    "hashPinned": true
  },
  "costPolicy": {
    "maxCostUsd": 1,
    "maxTokens": 8000,
    "warnAtPercent": 80
  },
  "retryPolicy": {
    "maxRetries": 1,
    "retryableErrors": ["model.rate_limit", "model.overloaded", "network.timeout"],
    "backoffBaseMs": 200,
    "backoffMaxMs": 1000
  }
}
